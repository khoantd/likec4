# AI Agent configuration
# Copy this file to .env and fill in your values

# --- LikeC4 Agent Server (CLI / VSCode) ---
# LiteLLM proxy or any OpenAI-compatible base URL. The agent server calls this
# (e.g. /v1/chat/completions), not the frontend. Do NOT point the playground at this.
LIKEC4_AGENT_URL=http://localhost:4000

# API key (optional for local proxies like Ollama)
# LIKEC4_AGENT_KEY=sk-your-api-key

# Model to use (default: gpt-4o)
# LIKEC4_AGENT_MODEL=gpt-4o

# Internal agent server port (default: 33336)
# LIKEC4_AGENT_PORT=33336

# --- Playground / frontend ---
# URL of the LikeC4 agent server (exposes /chat, /skills). Must be the agent server,
# NOT the LiteLLM URL — otherwise you get 404 on POST .../chat.
# VITE_LIKEC4_AGENT_URL=http://localhost:33336
